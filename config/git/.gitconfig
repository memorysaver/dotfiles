[user]
	name = Memorysaver
	email = mfa1484@gmail.com

[commit]
	template = ~/.gitmessage

[push]
	default = current

[github]
	user = memorysaver

[core]
	excludesfile = /Users/memorysaver/.gitignore_global
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
